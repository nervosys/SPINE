{
  "manifest_version": 3,
  "name": "SPINE Agent Bridge",
  "version": "1.0.0",
  "description": "Human-agent hybrid browsing — connects SPINE AI agents to web pages for collaborative intelligence",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:9800/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/spine-16.png",
      "48": "icons/spine-48.png",
      "128": "icons/spine-128.png"
    }
  },
  "icons": {
    "16": "icons/spine-16.png",
    "48": "icons/spine-48.png",
    "128": "icons/spine-128.png"
  }
}
